{
  "uid": "clawbernetes-fleet",
  "title": "Clawbernetes Fleet Overview",
  "description": "Fleet-wide monitoring for Clawbernetes AI agents.",
  "tags": ["clawbernetes", "fleet", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Fleet Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total LLM Calls",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{span.gen_ai.operation.name = \"chat\"}",
          "tableType": "traces",
          "limit": 500
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["count"], "fields": "/traceID/", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 5 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Agents",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{span.gen_ai.operation.name = \"chat\"}",
          "tableType": "traces",
          "limit": 500
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "traceService": { "aggregations": ["uniqueValues"], "operation": "groupby" }
            }
          }
        },
        {
          "id": "reduce",
          "options": { "reducers": ["count"] }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "purple", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Recent LLM Calls",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 1 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{span.gen_ai.operation.name = \"chat\"}",
          "tableType": "traces",
          "limit": 20
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceDuration" },
            "properties": [
              { "id": "unit", "value": "ns" },
              { "id": "displayName", "value": "Duration" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "traceService" },
            "properties": [{ "id": "displayName", "value": "Agent" }]
          },
          {
            "matcher": { "id": "byName", "options": "traceName" },
            "properties": [{ "id": "displayName", "value": "Operation" }]
          },
          {
            "matcher": { "id": "byName", "options": "nested" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      }
    },
    {
