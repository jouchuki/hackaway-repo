      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": { "mode": "continuous-BlYlRd" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5000000000 },
            { "color": "red", "value": 30000000000 }
          ]}
        },
        "overrides": []
      }
    },
