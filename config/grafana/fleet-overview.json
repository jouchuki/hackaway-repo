            }
          }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": true },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
